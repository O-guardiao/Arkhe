{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arkhe.dev/schemas/envelope.v1.json",
  "title": "Envelope",
  "description": "Unidade de transferência de mensagem entre canais externos e o Brain Python. Cruza a fronteira TypeScript→Python via WebSocket.",
  "type": "object",
  "required": [
    "id",
    "source_channel",
    "source_id",
    "source_client_id",
    "direction",
    "message_type",
    "text",
    "timestamp"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "UUID hex único da mensagem (32 chars, sem hífens)",
      "pattern": "^[0-9a-f]{32}$",
      "examples": ["a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4"]
    },
    "correlation_id": {
      "type": ["string", "null"],
      "description": "ID da mensagem que originou esta (para rastreio de conversas)",
      "default": null
    },
    "reply_to_id": {
      "type": ["string", "null"],
      "description": "ID da mensagem à qual esta é uma resposta direta",
      "default": null
    },
    "source_channel": {
      "type": "string",
      "description": "Nome do canal de origem",
      "enum": ["telegram", "discord", "slack", "whatsapp", "webchat", "api", "internal"],
      "examples": ["telegram"]
    },
    "source_id": {
      "type": "string",
      "description": "Identificador do usuário/entidade no canal de origem",
      "minLength": 1,
      "examples": ["123456789"]
    },
    "source_client_id": {
      "type": "string",
      "description": "ID composto padronizado: {channel}:{source_id}",
      "pattern": "^[a-z]+:.+$",
      "examples": ["telegram:123456789"]
    },
    "target_channel": {
      "type": ["string", "null"],
      "description": "Canal de destino para mensagens outbound",
      "default": null
    },
    "target_id": {
      "type": ["string", "null"],
      "description": "ID do destinatário no canal de destino",
      "default": null
    },
    "target_client_id": {
      "type": ["string", "null"],
      "description": "ID composto do destinatário: {channel}:{id}",
      "default": null
    },
    "direction": {
      "type": "string",
      "description": "Direção do fluxo da mensagem",
      "enum": ["inbound", "outbound", "internal"],
      "examples": ["inbound"]
    },
    "message_type": {
      "type": "string",
      "description": "Tipo semântico da mensagem",
      "enum": [
        "text",
        "image",
        "audio",
        "video",
        "document",
        "location",
        "command",
        "event",
        "action",
        "system"
      ],
      "default": "text"
    },
    "text": {
      "type": "string",
      "description": "Conteúdo textual principal da mensagem",
      "maxLength": 65536,
      "examples": ["Olá, preciso de ajuda com Python"]
    },
    "media_url": {
      "type": ["string", "null"],
      "description": "URL do arquivo de mídia (imagem, áudio, vídeo, documento)",
      "format": "uri",
      "default": null
    },
    "media_mime": {
      "type": ["string", "null"],
      "description": "MIME type do arquivo de mídia",
      "examples": ["image/jpeg", "audio/ogg", "application/pdf"],
      "default": null
    },
    "metadata": {
      "type": "object",
      "description": "Dados adicionais específicos do canal (chat_id, message_id, etc.)",
      "additionalProperties": true,
      "default": {}
    },
    "timestamp": {
      "type": "string",
      "description": "Timestamp ISO 8601 de criação do envelope",
      "format": "date-time",
      "examples": ["2025-01-15T10:30:00.000Z"]
    },
    "delivery_attempts": {
      "type": "integer",
      "description": "Número de tentativas de entrega realizadas",
      "minimum": 0,
      "default": 0
    },
    "max_retries": {
      "type": "integer",
      "description": "Máximo de tentativas de entrega permitidas",
      "minimum": 0,
      "maximum": 10,
      "default": 3
    },
    "priority": {
      "type": "integer",
      "description": "Prioridade de processamento: -1 (baixa), 0 (normal), 1 (alta)",
      "enum": [-1, 0, 1],
      "default": 0
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "id": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4",
      "correlation_id": null,
      "reply_to_id": null,
      "source_channel": "telegram",
      "source_id": "123456789",
      "source_client_id": "telegram:123456789",
      "target_channel": null,
      "target_id": null,
      "target_client_id": null,
      "direction": "inbound",
      "message_type": "text",
      "text": "Olá, preciso de ajuda com Python",
      "media_url": null,
      "media_mime": null,
      "metadata": {
        "chat_id": 123456789,
        "message_id": 42,
        "update_id": 1000001
      },
      "timestamp": "2025-01-15T10:30:00.000Z",
      "delivery_attempts": 0,
      "max_retries": 3,
      "priority": 0
    }
  ]
}
