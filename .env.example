# =============================================================================
# Arkhe — Arquivo de configuração (.env)
#
# Copie este arquivo para .env e preencha os valores necessários.
# O wizard interativo `arkhe setup` gera este arquivo automaticamente.
#
# Variáveis marcadas com [OBRIGATÓRIO] são necessárias para o funcionamento.
# Variáveis marcadas com [OPCIONAL] têm defaults sensatos.
# Compatibilidade: nomes `RLM_*` permanecem nesta etapa para não quebrar instalações existentes.
# =============================================================================


# =============================================================================
# 1. LLM — Credenciais do provedor de IA
# =============================================================================

# [OBRIGATÓRIO] Pelo menos UMA chave de API de LLM deve estar presente.
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...
# GEMINI_API_KEY=AIza...

# Modelo padrão usado pelo servidor e gateways.
# Exemplos: gpt-4o-mini, gpt-4o, gpt-5-nano, claude-3-5-haiku, gemini-2.0-flash
RLM_MODEL=gpt-4o-mini

# Policy de roteamento por responsabilidade (opcional).
# Planner/orquestração raiz. Se vazio, usa RLM_MODEL.
# RLM_MODEL_PLANNER=gpt-5.4

# Worker/subagente/evaluator. Se vazio, usa RLM_MODEL_PLANNER.
# RLM_MODEL_WORKER=gpt-5.4-mini
# RLM_MODEL_EVALUATOR=gpt-5.4-mini

# Fast-path para verificações simples e respostas operacionais curtas.
# RLM_MODEL_FAST=gpt-5.4-nano

# Minirepl/classificação muito barata.
# RLM_MODEL_MINIREPL=gpt-5-nano

# Backend de LLM: openai | anthropic | google | portkey | litellm
RLM_BACKEND=openai

# Profundidade máxima de recursão do runtime (sub-calls)
# RLM_MAX_DEPTH=2


# =============================================================================
# 2. Servidor — Endereços e portas
# =============================================================================

# Host/porta da API REST FastAPI (loopback = seguro por padrão)
# NUNCA use 0.0.0.0 sem reverse proxy + TLS.
RLM_API_HOST=127.0.0.1
RLM_API_PORT=5000

# Host/porta do servidor WebSocket (observabilidade em tempo real)
RLM_WS_HOST=127.0.0.1
RLM_WS_PORT=8765

# Host interno usado por gateways para chamar a API localmente
# RLM_INTERNAL_HOST=http://127.0.0.1:5000

# Host opcional usado por TUI/operator/doctor para acessar a API viva.
# Não confundir com RLM_INTERNAL_HOST, que é para bridges internos.
# RLM_OPERATOR_HOST=http://127.0.0.1:5000

# Origens permitidas para CORS (vírgula-separado). Vazio = bloqueia tudo.
# Exemplo: http://localhost:3000,https://meusite.com
# RLM_CORS_ORIGINS=


# =============================================================================
# 3. Segurança — Tokens e autenticação
# =============================================================================

# Token de autenticação do WebSocket. Mínimo 32 chars. Gerado por `arkhe setup`.
# Clientes enviam via ?token=<valor> ou Authorization: Bearer <valor>
RLM_WS_TOKEN=

# Token interno para POST /webhook/{client_id}. Se vazio, usa RLM_WS_TOKEN.
# Gateways e WebChat devem enviar via header X-RLM-Token.
# RLM_INTERNAL_TOKEN=

# Token para receber webhooks externos em POST /api/hooks/{token}
RLM_HOOK_TOKEN=

# Token para a API OpenAI-compatible em POST /v1/chat/completions
# Clientes enviam via Authorization: Bearer <valor>
# RLM_API_TOKEN=

# Token administrativo para endpoints de sessão, scheduler, hooks, skills e health.
# Se vazio, usa RLM_API_TOKEN e depois RLM_WS_TOKEN.
# RLM_ADMIN_TOKEN=

# Secret para JWT (autenticação avançada). Mínimo 32 chars.
# Necessário apenas se usar endpoints com autenticação JWT.
# RLM_JWT_SECRET=


# =============================================================================
# 4. Engine — Limites e comportamento do Arkhe
# =============================================================================

# Número máximo de iterações REPL por completion (previne loops infinitos)
RLM_MAX_ITERATIONS=30

# Timeout global de execução em segundos
RLM_TIMEOUT=120

# Erros consecutivos antes do abort automático
RLM_MAX_ERRORS=5

# Rate limit de mensagens por minuto (Telegram gateway)
# RLM_RATE_LIMIT=10

# IDs de chat permitidos (Telegram). Vazio = todos permitidos.
# Formato: vírgula-separado. Ex: 123456,789012
# RLM_ALLOWED_CHATS=

# Ativar modo sandbox forçado (impede uso do LocalREPL)
# RLM_SANDBOX=1

# Nível de log: debug, info, warning, error
# RLM_LOG_LEVEL=info


# =============================================================================
# 5. Persistência — Banco de dados e estado
# =============================================================================

# Caminho do SQLite de sessões
# RLM_DB_PATH=rlm_sessions.db

# Diretório para salvar estados de sessão (JSON)
# RLM_STATE_ROOT=./rlm_states

# Caminho do SQLite do scheduler
# RLM_SCHEDULER_DB=~/.rlm/scheduler.db

# Número de workers do scheduler para tarefas paralelas
# RLM_SCHEDULER_WORKERS=4


# =============================================================================
# 6. Aprovação de Execução — Gate de segurança
# =============================================================================

# Exigir aprovação manual antes de executar código no REPL
# RLM_EXEC_APPROVAL_REQUIRED=false

# Timeout em segundos para aguardar aprovação (0 = sem timeout)
# RLM_EXEC_APPROVAL_TIMEOUT=60


# =============================================================================
# 7. Skills — Diretório de habilidades
# =============================================================================

# Diretório contendo as skills (SKILL.md). Default: rlm/skills/
# RLM_SKILLS_DIR=

# Desabilitar o webchat integrado
# RLM_WEBCHAT_DISABLED=false


# =============================================================================
# 8. Canal — Telegram
# =============================================================================

# Token do bot Telegram (obtido via @BotFather)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Chat ID para notificações do scheduler
# TELEGRAM_CHAT_ID=


# =============================================================================
# 9. Canal — Discord
# =============================================================================

# Chave pública do app Discord (para verificação de interações)
# DISCORD_APP_PUBLIC_KEY=

# Application ID do Discord
# DISCORD_APP_ID=

# Webhook URL para enviar mensagens outbound
# DISCORD_WEBHOOK_URL=

# Bot token para operações avançadas (presença, DM, etc.)
# DISCORD_BOT_TOKEN=

# Pular verificação de assinatura do Discord (apenas para dev local)
# RLM_DISCORD_SKIP_VERIFY=false


# =============================================================================
# 10. Canal — WhatsApp (Meta Cloud API)
# =============================================================================

# Token de acesso permanente da WhatsApp Business API
# WHATSAPP_TOKEN=

# Phone Number ID (obtido no painel Meta Business)
# WHATSAPP_PHONE_ID=

# Token de verificação de webhook (você define este valor no Meta)
# WHATSAPP_VERIFY_TOKEN=

# App Secret para verificação HMAC-SHA256 de webhooks
# WHATSAPP_APP_SECRET=


# =============================================================================
# 11. Canal — Slack
# =============================================================================

# Bot Token do Slack (xoxb-...)
# SLACK_BOT_TOKEN=

# Signing Secret do app Slack (para verificar requests)
# SLACK_SIGNING_SECRET=

# App ID do Slack
# SLACK_APP_ID=

# Webhook URL para enviar mensagens outbound
# SLACK_WEBHOOK_URL=


# =============================================================================
# 12. Ambientes de execução (REPL)
# =============================================================================

# Para Docker REPL:
# RLM_DOCKER_BASE_DIR=/tmp/rlm_docker

# Para Modal Sandboxes:
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=

# Para Prime Intellect Sandboxes:
# PRIME_API_KEY=

# Para Daytona Sandboxes:
# DAYTONA_API_KEY=
